# Open Video Studio production/development environment template.
# Copy this file to .env.local for local development.
# Never commit real secrets.

NODE_ENV=development
APP_URL=http://127.0.0.1:4173

# Supabase public client configuration.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Telegram Login Widget. Requires a Telegram bot and backend auth URL that validates Telegram hash.
VITE_TELEGRAM_BOT_USERNAME=your_bot_username
VITE_TELEGRAM_AUTH_URL=https://your-project-ref.supabase.co/functions/v1/telegram-auth

# Public OAuth readiness gates.
# Keep false until the provider works end-to-end in Supabase and its third-party dashboard.
VITE_GOOGLE_OAUTH_READY=false
VITE_X_OAUTH_READY=false
VITE_DISCORD_OAUTH_READY=false
VITE_TELEGRAM_OAUTH_READY=false

# Payment provider public configuration.
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_PAYPAL_CLIENT_ID=

# Supabase Storage.
SUPABASE_STORAGE_BUCKET=open-video-studio-assets
VITE_SUPABASE_STORAGE_BUCKET=open-video-studio-assets

# Optional server-only key for trusted backend jobs.
# Do not expose this to browsers and do not commit real values.
SUPABASE_SERVICE_ROLE_KEY=
TELEGRAM_BOT_TOKEN=
AUTH_ALLOWED_REDIRECT_ORIGINS=https://jiang289140790-eng.github.io,https://luravyn.com,http://127.0.0.1:4173
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400

# Server-only payment provider secrets. Set as Supabase Edge Function secrets in production.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MODE=test
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_ENVIRONMENT=sandbox

# Future AI providers. Leave empty until providers are connected.
OPENAI_API_KEY=
GEMINI_API_KEY=
FAL_API_KEY=
COMFYUI_BASE_URL=
RUNPOD_API_KEY=

# Server-only AI provider secrets. Set as Supabase Edge Function secrets in production.
QWEN_VISION_ENDPOINT=https://47-251-244-196.sslip.io/api/ai/vision/analyze
QWEN_VISION_SITE_API_KEY=
QWEN_VISION_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
QIANWEN_API_KEY=
QIANWEN_BASE_URL=
QIANWEN_IMAGE_ENDPOINT=
QIANWEN_VIDEO_ENDPOINT=
QIANWEN_IMAGE_MODEL=your-image-model
QIANWEN_VIDEO_MODEL=your-video-model
QIANWEN_MAX_POLLS=36
QIANWEN_POLL_INTERVAL_MS=5000
LIBLIB_ACCESS_KEY=
LIBLIB_SECRET_KEY=
LIBLIB_BASE_URL=https://openapi.liblibai.cloud
LIBLIB_TEXT2IMG_TEMPLATE_UUID=
LIBLIB_IMAGE_MODEL=liblib-text2img-v1
LIBLIB_MAX_POLLS=12
LIBLIB_POLL_INTERVAL_MS=5000
ZEALMAN_PANEL_BASE_URL=https://your-zealman-panel.example.com
ZEALMAN_COMFY_BASE_URL=https://your-comfyui.example.com
ZEALMAN_API_TOKEN=
ZEALMAN_IMAGE_WORKFLOW=your-a01-image-workflow.json
ZEALMAN_IMAGE_EDIT_WORKFLOW=E01-qwen-edit.json
ZEALMAN_VIDEO_WORKFLOW=your-g01-image-to-video-workflow.json
ZEALMAN_SMOOTH_VIDEO_WORKFLOW=your-g03-smooth-video-workflow.json
ZEALMAN_DIGITAL_HUMAN_WORKFLOW=your-j11-digital-human-workflow.json
ZEALMAN_PROMPT_NODE_ID=
ZEALMAN_MAX_POLLS=180
ZEALMAN_POLL_INTERVAL_MS=5000

# Optional GPU lifecycle control for a stopped-by-default Compshare instance.
# Keep both keys in Supabase Edge Function Secrets only.
COMPSHARE_API_BASE_URL=https://api.compshare.cn
COMPSHARE_PUBLIC_KEY=
COMPSHARE_PRIVATE_KEY=
COMPSHARE_PROJECT_ID=
COMPSHARE_REGION=cn-wlcb
COMPSHARE_ZONE=cn-wlcb-01
COMPSHARE_INSTANCE_ID=
COMPSHARE_COLD_START_TIMEOUT_MS=240000
COMPSHARE_POLL_INTERVAL_MS=5000
COMPSHARE_IDLE_SHUTDOWN_SECONDS=600
CIVITAI_API_TOKEN=
HF_TOKEN=
COMFYUI_ROOT=
ASSET_STORAGE_DIR=.data/ai-assets/downloads
AI_ASSET_DB_PATH=.data/ai-assets/assets.sqlite
AI_PROVIDER_DEFAULT=fake_worker
AI_PROVIDER_ROLLOUT_MODE=admin_config
AI_PROVIDER_TIMEOUT_MS=60000
