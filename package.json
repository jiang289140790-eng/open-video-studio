{
  "name": "open-video-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "node scripts/repair-css-encoding.mjs && tsc -p tsconfig.json && vite build && node scripts/copy-web-assets.mjs",
    "build:server": "tsc -p tsconfig.json",
    "build:web": "vite build",
    "seo:apply": "node scripts/apply-seo.mjs",
    "verify:supabase": "node scripts/verify-supabase.mjs",
    "verify:auth-basic": "node scripts/verify-basic-auth.mjs",
    "verify:oauth": "node scripts/verify-oauth.mjs",
    "verify:i18n": "node scripts/verify-i18n.mjs",
    "verify:ai": "node scripts/verify-ai-function.mjs",
    "verify:workflow": "node scripts/verify-workflow-routing.mjs",
    "verify:user-loop": "node scripts/verify-user-product-loop.mjs",
    "verify:real-ai": "node scripts/verify-real-ai-generation.mjs",
    "verify:payments": "node scripts/verify-payment-loop.mjs",
    "verify:mvp": "node scripts/verify-mvp-readiness.mjs",
    "verify:production-config": "node scripts/check-production-config.mjs",
    "verify:admin": "node scripts/verify-admin-console.mjs",
    "verify:ai-assets": "npm run build:server && node --test dist/tests/ai-assets-mcp.test.js",
    "mcp:ai-assets": "node dist/src/mcp/ai-assets/index.js",
    "deploy:function": "node scripts/deploy-supabase-function.mjs",
    "test": "npm run build && node --test dist/tests/**/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.110.0",
    "@vitejs/plugin-react": "^6.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^8.1.3"
  }
}
