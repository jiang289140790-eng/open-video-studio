# Open Video Studio production/development environment template.
# Copy this file to .env.local for local development.
# Never commit real secrets.

NODE_ENV=development
APP_URL=http://127.0.0.1:4173

# Supabase public client configuration.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Telegram Login Widget. Requires a Telegram bot and backend auth URL that validates Telegram hash.
VITE_TELEGRAM_BOT_USERNAME=your_bot_username
VITE_TELEGRAM_AUTH_URL=https://your-domain.example.com/auth/telegram/callback

# Supabase Storage.
SUPABASE_STORAGE_BUCKET=open-video-studio-assets

# Optional server-only key for trusted backend jobs.
# Do not expose this to browsers and do not commit real values.
SUPABASE_SERVICE_ROLE_KEY=

# Future AI providers. Leave empty until providers are connected.
OPENAI_API_KEY=
GEMINI_API_KEY=
FAL_API_KEY=
COMFYUI_BASE_URL=
RUNPOD_API_KEY=
