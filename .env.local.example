# Local environment example for Open Video Studio.
# Copy to .env.local and replace placeholders with your existing Supabase project values.

NODE_ENV=development
APP_URL=http://127.0.0.1:4173

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_STORAGE_BUCKET=open-video-studio-assets

# Server-only. Required only for backend admin jobs or migrations.
SUPABASE_SERVICE_ROLE_KEY=

OPENAI_API_KEY=
GEMINI_API_KEY=
FAL_API_KEY=
COMFYUI_BASE_URL=
RUNPOD_API_KEY=
