# Local environment example for Open Video Studio.
# Copy to .env.local and replace placeholders with your existing Supabase project values.

NODE_ENV=development
APP_URL=http://127.0.0.1:4173

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_TELEGRAM_BOT_USERNAME=your_bot_username
VITE_TELEGRAM_AUTH_URL=http://127.0.0.1:4173/auth/telegram/callback
SUPABASE_STORAGE_BUCKET=open-video-studio-assets

# Server-only. Required only for backend admin jobs or migrations.
SUPABASE_SERVICE_ROLE_KEY=

OPENAI_API_KEY=
GEMINI_API_KEY=
FAL_API_KEY=
COMFYUI_BASE_URL=
RUNPOD_API_KEY=

QWEN_VISION_ENDPOINT=https://47-251-244-196.sslip.io/api/ai/vision/analyze
QWEN_VISION_SITE_API_KEY=
QWEN_VISION_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
QIANWEN_API_KEY=
QIANWEN_BASE_URL=
QIANWEN_IMAGE_ENDPOINT=
QIANWEN_VIDEO_ENDPOINT=
QIANWEN_IMAGE_MODEL=your-image-model
QIANWEN_VIDEO_MODEL=your-video-model
QIANWEN_MAX_POLLS=24
QIANWEN_POLL_INTERVAL_MS=5000
LIBLIB_ACCESS_KEY=
LIBLIB_SECRET_KEY=
LIBLIB_BASE_URL=https://openapi.liblibai.cloud
LIBLIB_TEXT2IMG_TEMPLATE_UUID=
LIBLIB_IMAGE_MODEL=liblib-text2img-v1
LIBLIB_MAX_POLLS=12
LIBLIB_POLL_INTERVAL_MS=5000
CIVITAI_API_TOKEN=
HF_TOKEN=
COMFYUI_ROOT=
ASSET_STORAGE_DIR=.data/ai-assets/downloads
AI_ASSET_DB_PATH=.data/ai-assets/assets.sqlite
AI_PROVIDER_DEFAULT=fake_worker
AI_PROVIDER_ROLLOUT_MODE=admin_config
AI_PROVIDER_TIMEOUT_MS=60000
