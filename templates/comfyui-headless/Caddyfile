{$GATEWAY_PUBLIC_HOST} {
  encode zstd gzip
  reverse_proxy 127.0.0.1:{$GATEWAY_PORT:7860}

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "no-referrer"
    -Server
  }

  log {
    output file {$CADDY_ACCESS_LOG:/root/ovs-headless/caddy-access.log}
    format json
  }
}
